# Local development (Docker Compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gisdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# API connection string (local)
DATABASE_URL=Host=${POSTGRES_HOST};Port=${POSTGRES_PORT};Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}

# Supabase — used by gis-web for direct reads, and by gis-api in production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# API CORS — browser origins allowed to call gis-api in production.
# Bound as an array: Cors__AllowedOrigins__0, __1, ... (unset locally = Vite dev server).
Cors__AllowedOrigins__0=https://your-app.pages.dev
