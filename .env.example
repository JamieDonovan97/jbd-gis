# Local development (Docker Compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gisdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# API connection string (local)
DATABASE_URL=Host=${POSTGRES_HOST};Port=${POSTGRES_PORT};Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}

# Supabase — used by gis-web for direct reads, and by gis-api in production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# API CORS — browser origins allowed to call gis-api in production.
# Bound as an array: Cors__AllowedOrigins__0, __1, ... (unset locally = Vite dev server).
Cors__AllowedOrigins__0=https://your-app.pages.dev

# gis-engine → R2 (Terrain-RGB tile uploads). Secrets — never commit real values.
# Endpoint and keys come from an R2 API token scoped to the bucket, write access.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=jbd-gis-tiles
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public read domain the frontend fetches from (r2.dev URL or a custom domain).
R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev
